# Local app defaults. Copy to .env for local Docker or non-Docker development.
POSTGRES_DB=timeline
POSTGRES_USER=timeline
POSTGRES_PASSWORD=timeline
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

# Optional compatibility override. If set, this wins over the split POSTGRES_* vars.
# DATABASE_URL=postgres://timeline:timeline@localhost:5433/timeline

# VPS / Traefik deployment.
TIMELINE_HOST=timeline.example.com
TIMELINE_IMAGE=ghcr.io/your-github-user-or-org/timeline:latest
TRAEFIK_CERT_RESOLVER=letsencrypt
